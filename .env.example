# Application
APP_NAME=Automation Tool
APP_ENV=development
DEBUG=true
API_V1_PREFIX=/api/v1

# Security
JWT_SECRET=change-me-to-a-long-random-secret-key
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440
FERNET_KEY=generate-with-python-cryptography-fernet-generate-key

# LLM Provider: nvidia | openai | lmstudio (local LM Studio OpenAI-compatible API)
LLM_PROVIDER=lmstudio

# Hybrid routing: hybrid (NVIDIA brain scan + NVIDIA chat/analysis) | local | cloud
LLM_ROUTING_MODE=hybrid
SCAN_LLM_PROVIDER=nvidia

NVIDIA_API_KEY=nvapi-your-nvidia-api-key
NVIDIA_API_BASE=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL=minimaxai/minimax-m3
NVIDIA_CHAT_MODEL=z-ai/glm-5.2
NVIDIA_SCAN_MODEL=google/gemma-4-31b-it
NVIDIA_ANALYSIS_MODEL=google/gemma-4-31b-it
NVIDIA_AUTOMATION_MODEL=z-ai/glm-5.2
NVIDIA_MAX_TOKENS=16384
NVIDIA_TEMPERATURE=0.3
NVIDIA_CHAT_TEMPERATURE=1.0
NVIDIA_SCAN_TEMPERATURE=0.2
NVIDIA_ANALYSIS_TEMPERATURE=1.0
NVIDIA_ENABLE_THINKING=true
LLM_FIELD_FALLBACK=false

# OpenAI (fallback if LLM_PROVIDER=openai)
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4o

# LM Studio — OpenAI-compatible API at http://127.0.0.1:1234/v1
# Docker backend: use http://host.docker.internal:1234/v1 to reach LM Studio on the host
# Verify loaded models: GET http://127.0.0.1:1234/v1/models
# Use host.docker.internal when the backend runs in Docker; 127.0.0.1 for local-only backend.
LMSTUDIO_API_BASE=http://host.docker.internal:1234/v1
LMSTUDIO_API_KEY=lm-studio
LMSTUDIO_MODEL=mistralai/devstral-small-2505
LMSTUDIO_EMBEDDING_MODEL=text-embedding-nomic-embed-text-v1.5
LMSTUDIO_MAX_TOKENS=8192
LMSTUDIO_TEMPERATURE=0.3

# Code Brain — scan/brain/graphify use NVIDIA Gemma; embeddings stay on LM Studio
BRAIN_AGENT_MODE=multi
LMSTUDIO_BRAIN_API_BASE=http://host.docker.internal:1234/v1
LMSTUDIO_BRAIN_MODEL=mistralai/devstral-small-2505

# Legacy local multi-agent ports (optional; hybrid mode uses NVIDIA for RCA/vision instead)
# LMSTUDIO_RCA_API_BASE=http://127.0.0.1:1235/v1
# LMSTUDIO_RCA_MODEL=qwen/qwen3.6-35b-a3b
# LMSTUDIO_VISION_API_BASE=http://127.0.0.1:1236/v1
# LMSTUDIO_VISION_MODEL=google/gemma-4-26b-a4b-qat

# Knowledge Engine
CHROMA_DIR=./data/chroma
AZURE_DEVOPS_WORKSPACE_DIR=./data/azure_workspaces
# Azure PAT is stored per-user in the database after connecting in the Knowledge UI

# Test pack mode: paste multi-TC content in scenario test_pack_content or upload .xlsx/.csv

# Firebase
FIREBASE_PROJECT_ID=code-automation-tool
FIREBASE_CREDENTIALS_PATH=
# Seconds of clock drift allowed when verifying Firebase ID tokens (default 60)
FIREBASE_TOKEN_CLOCK_SKEW_SECONDS=60

# PostgreSQL
DATABASE_URL=postgresql+asyncpg://aiqa:aiqa_secret@localhost:5433/aiqa_db

# Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=neo4j_secret

# CORS
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3001

# Storage
UPLOAD_DIR=./uploads
ARTIFACTS_DIR=./artifacts

# Playwright
PLAYWRIGHT_HEADLESS=false
PLAYWRIGHT_TIMEOUT_MS=30000
PLAYWRIGHT_VIEWPORT_WIDTH=1366
PLAYWRIGHT_VIEWPORT_HEIGHT=768
# Optional. Leave unset locally; app auto-detects valid install path (ignores Cursor sandbox cache).
# Docker/hosted: use /ms-playwright when using the official Playwright image.
# PLAYWRIGHT_BROWSERS_PATH=/ms-playwright

# Frontend (also used as Docker build args for NEXT_PUBLIC_FIREBASE_*)
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_WS_URL=ws://localhost:8000/api/v1
NEXT_PUBLIC_FIREBASE_API_KEY=your-firebase-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=code-automation-tool.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=code-automation-tool
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=code-automation-tool.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
NEXT_PUBLIC_FIREBASE_APP_ID=your-app-id
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=your-measurement-id

# Salesforce OAuth — optional overrides (defaults use SF CLI / VS Code: PlatformCLI + localhost:1717)
# SALESFORCE_OAUTH_CLIENT_ID=your_connected_app_consumer_key
# SALESFORCE_OAUTH_CLIENT_SECRET=your_connected_app_consumer_secret
# SALESFORCE_OAUTH_REDIRECT_URI=http://localhost:3000/salesforce-orgs/oauth/callback
