# Application
APP_NAME=AI QA Agent
APP_ENV=development
DEBUG=true
API_V1_PREFIX=/api/v1

# Security
JWT_SECRET=change-me-to-a-long-random-secret-key
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440
FERNET_KEY=generate-with-python-cryptography-fernet-generate-key

# LLM Provider: nvidia | openai
LLM_PROVIDER=nvidia
NVIDIA_API_KEY=nvapi-your-nvidia-api-key
NVIDIA_API_BASE=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL=minimaxai/minimax-m3
NVIDIA_MAX_TOKENS=8192
NVIDIA_TEMPERATURE=0.3
LLM_FIELD_FALLBACK=false

# OpenAI (fallback if LLM_PROVIDER=openai)
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4o

# Firebase
FIREBASE_PROJECT_ID=automation-tool-29a9c
FIREBASE_CREDENTIALS_PATH=

# PostgreSQL
DATABASE_URL=postgresql+asyncpg://aiqa:aiqa_secret@localhost:5432/aiqa_db

# Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=neo4j_secret

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Storage
UPLOAD_DIR=./uploads
ARTIFACTS_DIR=./artifacts

# Playwright
PLAYWRIGHT_HEADLESS=true
PLAYWRIGHT_TIMEOUT_MS=30000
PLAYWRIGHT_VIEWPORT_WIDTH=1366
PLAYWRIGHT_VIEWPORT_HEIGHT=768

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_WS_URL=ws://localhost:8000/api/v1
